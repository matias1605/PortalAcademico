@model PortalAcademico.Models.Curso
@{
    ViewData["Title"] = "Crear Curso";
}

<h1 class="h3 mb-4">➕ Crear Nuevo Curso</h1>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-body">
        <form asp-controller="Coordinador" asp-action="CrearCurso" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Codigo" class="form-label fw-bold"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Creditos" class="form-label fw-bold"></label>
                    <input asp-for="Creditos" type="number" class="form-control" min="1" />
                    <span asp-validation-for="Creditos" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="CupoMaximo" class="form-label fw-bold"></label>
                    <input asp-for="CupoMaximo" type="number" class="form-control" min="1" />
                    <span asp-validation-for="CupoMaximo" class="text-danger small"></span>
                </div>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="HorarioInicio" class="form-label fw-bold"></label>
                    <input asp-for="HorarioInicio" type="time" class="form-control" />
                    <span asp-validation-for="HorarioInicio" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="HorarioFin" class="form-label fw-bold"></label>
                    <input asp-for="HorarioFin" type="time" class="form-control" />
                    <span asp-validation-for="HorarioFin" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Activo" class="form-check-input" type="checkbox" />
                <label asp-for="Activo" class="form-check-label">Activo</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-controller="Coordinador" asp-action="Index"
                   class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>