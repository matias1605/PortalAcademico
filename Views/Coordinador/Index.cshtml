@model List<PortalAcademico.Models.Curso>
@using PortalAcademico.Models
@{
    ViewData["Title"] = "Panel Coordinador";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">⚙️ Panel Coordinador</h1>
    <a asp-controller="Coordinador" asp-action="CrearCurso"
       class="btn btn-primary">➕ Nuevo Curso</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Código</th><th>Nombre</th><th>Créditos</th>
                <th>Cupo</th><th>Matriculados</th><th>Horario</th>
                <th>Estado</th><th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@c.Codigo</span></td>
                    <td>@c.Nombre</td>
                    <td>@c.Creditos</td>
                    <td>@c.CupoMaximo</td>
                    <td>@c.Matriculas.Count(m => m.Estado != EstadoMatricula.Cancelada)</td>
                    <td>@c.HorarioInicio.ToString("HH:mm") – @c.HorarioFin.ToString("HH:mm")</td>
                    <td>
                        @if (c.Activo)
                        { <span class="badge bg-success">Activo</span> }
                        else
                        { <span class="badge bg-danger">Inactivo</span> }
                    </td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-controller="Coordinador" asp-action="EditarCurso"
                               asp-route-id="@c.Id"
                               class="btn btn-warning btn-sm">Editar</a>
                            <a asp-controller="Coordinador" asp-action="Matriculas"
                               asp-route-id="@c.Id"
                               class="btn btn-info btn-sm">Matrículas</a>
                            <form asp-controller="Coordinador"
                                  asp-action="DesactivarCurso"
                                  asp-route-id="@c.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(c.Activo ? "btn-danger" : "btn-success")"
                                        onclick="return confirm('¿Confirmar?')">
                                    @(c.Activo ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>