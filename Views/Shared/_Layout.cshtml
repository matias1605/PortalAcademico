
<!DOCTYPE html>
<html lang="es-PE">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Portal Académico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Cursos" asp-action="Index">
            🎓 Portal Académico
        </a>
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Cursos" asp-action="Index">
                        Catálogo
                    </a>
                </li>
                @if (User.IsInRole("Coordinador"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Coordinador" asp-action="Index">
                            ⚙️ Panel Coordinador
                        </a>
                    </li>
                }
            </ul>

            @* Último curso visitado (sesión Redis) *@
            @{
                var ultimoNombre = Context.Session.GetString("UltimoCursoNombre");
                var ultimoId     = Context.Session.GetString("UltimoCursoId");
            }
            @if (!string.IsNullOrEmpty(ultimoNombre))
            {
                <a class="btn btn-outline-light btn-sm me-3"
                   asp-controller="Cursos" asp-action="Detalle"
                   asp-route-id="@ultimoId">
                    ↩ Volver al curso: @ultimoNombre
                </a>
            }

            <ul class="navbar-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <span class="nav-link text-light">👤 @User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <form asp-area="Identity" asp-page="/Account/Logout"
                              asp-route-returnUrl="/" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                Salir
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Identity"
                           asp-page="/Account/Login">Ingresar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Identity"
                           asp-page="/Account/Register">Registrarse</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container mt-4">
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<footer class="footer mt-5 py-3 bg-light border-top">
    <div class="container text-center text-muted">
        <small>© 2025 Portal Académico USMP</small>
    </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</script>
</body>
</html>